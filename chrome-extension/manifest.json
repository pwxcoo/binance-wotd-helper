{
  "manifest_version": 3,
  "name": "BN助手",
  "version": "1.1.0",
  "description": "在 Binance 页面内提供 Alpha 价差监控和 WOTD 猜词辅助能力。",
  "permissions": ["activeTab", "storage", "notifications"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.binance.com/*/alpha/*"],
      "js": ["alpha_content.js"],
      "css": ["alpha_styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.binance.com/*"],
      "js": ["solver_core.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["wordlists/common_words.txt", "wordlists/full_words.txt"],
      "matches": ["*://www.binance.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
